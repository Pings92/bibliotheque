{% extends 'base.html.twig' %}

{% block title %}YACHAI TAQI{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="text-center mb-5" style="color: #1B263B; font-family: 'Georgia', serif;">Bienvenue chez YACHAI TAQI</h1>

    <div class="row g-4 justify-content-center"> {# g-4 ajoute de l'espace entre les cartes #}
        {% for book in books %}
            <div class="col-12 col-md-6 col-lg-4 d-flex justify-content-center"> {# Définit la taille sur mobile/tablette/pc #}
                <div class="card h-100 shadow-sm border-0 text-center" style="width: 20rem; background-color: #FFFFFF;">
                    
                    {# Image avec le ratio 2:3 dont on a parlé #}
                    <div style="aspect-ratio: 2/3; overflow: hidden;">
                        <img src="{{ asset('uploads/images/' ~ book.image) }}" 
                             class="card-img-top" 
                             alt="{{ book.title }}"
                             style="width: 100%; height: 100%; object-fit: cover;">
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title" style="color: #1B263B;">{{ book.title }}</h5>
                        <p class="card-text text-muted small">
                            {{ book.shortdescription|slice(0, 60) }}...
                        </p>
                        
                        {# Le mt-auto pousse le bouton vers le bas pour que tous les boutons soient alignés #}
                        <div class="mt-auto">
                            <a href="{{ path('app_emprunt_show', {'id': book.id}) }}" 
                               class="btn w-100" 
                               style="background-color: #1B263B; color: #F5EBE0;">
                                Consulter
                            </a>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pb-3">
                        {% if book.stock == 0 %}
                            <span class="badge" style="background-color: #E76F51;">Victime de son succès</span>
                        {% else %}
                            <span class="badge" style="background-color: #84A59D;">En stock ({{ book.stock }})</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}