{% extends 'base.html.twig' %}

{% block title %}YACHAI TAQI{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Bienvenue chez YACHAI TAQI</h1>
</div>
<div class="row">
    {% for book in books %}
        <div class="card" style="width: 18rem;">
        <img src="{{ asset('uploads/images/'~book.image)}}" class="card-img-top miniatures" alt="...">
        <div class="card-body">
            <h5 class="card-title">{{ book.title}}</h5>
            <p class="card-text"> {{ book.shortdescription|slice(0,60)}} ...</p>
            <a href="{{ path('app_emprunt_new', {'id': book.id}) }}" class="btn btn-primary">Consulter</a>
        </div>
        </div>
    {% endfor %}
</div>
<ul>

{% endblock %}
