{% extends 'base.html.twig' %}

{% block title %}Inventaire{% endblock %}

{% block body %}
<div class="container containerForm">
    
    {% include 'layouts/_flash_message.html.twig' %}

    <h1>📚 Catalogue des Livres</h1>

    <table class="table">
        <thead>
            <tr>
                {# <th>Id</th> #}
                <th>Titre</th>
                <th>Auteur</th>
                {% if app.user %}
                    <th>ISBN</th>
                    <th>Stock</th>
                {% endif %}
                <th>Résumé</th>
                {% if app.user %}
                    <th>Action</th>
                {% endif %}
            </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                {# <td>{{ book.id }}</td> #}
                <td>{{ book.title }}</td>
                <td>{{ book.author }}</td>
                {% if app.user %}
                    <td >{{ book.isbn }}</td>
                    {% if book.stock == 0 %}
                        <td><span class="badge bg-danger" role="badge">Indisponible</span></td>
                    {% else %}
                        <td class="text-success">{{ book.stock }}</td>
                    {% endif %}
                {% endif %}
                    <td>{{ book.shortdescription |slice(0,60) }} ...</td>
                {% if app.user %}
                        {% if book.stock == 0 %}
                            <td> <span class="btn btn-secondary">Emprunter</span></td>
                        {% else %}
                            <td> <a href="{{ path('app_emprunt_new', {'id': book.id}) }}" class="btn btn-info">Emprunter</a></td>
                        {% endif %}
                {% endif %}

            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucune entrée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
{% endblock %}
