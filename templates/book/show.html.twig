{% extends 'base.html.twig' %}

{% block title %}Book{% endblock %}

{% block body %}
<div class='container containerForm'>
    <h1>Ouvrage</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ book.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ book.title }}</td>
            </tr>
            <tr>
                <th>Auteur</th>
                <td>{{ book.author }}</td>
            </tr>
            <tr>
                <th>ISBN</th>
                <td>{{ book.isbn }}</td>
            </tr>
            <tr>
                <th>Stock</th>
                <td>{{ book.stock }}</td>
            </tr>
            <tr>
                <th>Synopsis</th>
                <td>{{ book.shortdescription }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{book.image}}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Retour à la liste</a>

    <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-primary">Modifier</a>

    {{ include('book/_delete_form.html.twig') }}
    </div>
{% endblock %}
