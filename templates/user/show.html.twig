{% extends 'base.html.twig' %}

{% block title %}User{% endblock %}

{% block body %}
<div class="container containerForm">

    <h1>User</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Roles</th>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ user.password }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ user.name }}</td>
            </tr>
            <tr>
                <th>Phone_number</th>
                <td>{{ user.phoneNumber }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_user_index') }}" class='btn btn-secondary'>Retour à la liste</a>

    <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-success">Modifier</a>

    {{ include('user/_delete_form.html.twig') }}
    </div>

{% endblock %}
