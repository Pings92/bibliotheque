{% extends 'base.html.twig' %}

{% block title %}Emprunt index{% endblock %}

{% block body %}
    <h1>Emprunt index</h1>

    <table class="table">
        <thead>
            <tr>
                {# <th>Id</th> #}
                <th>Nom du livre</th>
                <th>Date emprunt</th>
                <th>Date retour</th>
                <th>Statut</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for emprunt in emprunts %}
            <tr>
                {# <td>{{ emprunt.id }}</td> #}
                <td>{{ emprunt.book.title }}</td>
                <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('Y-m-d') : '' }}</td>
                <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('Y-m-d') : '' }}</td>
                <td>{{ emprunt.statut }}</td>
                <td>
                    {% if emprunt.statut == "en cours" %}
                        <a href="{{path('app_emprunt_return', {'id': emprunt.id}) }}" class="btn btn-primary">Restituer</a>
                    {# <a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}">Restituer</a> #}
                    {% else %}
                        <p><span class="badge bdg-succes">Restitué</span></p>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {# <a href="{{ path('app_emprunt_new') }}">Create new</a> #}
{% endblock %}
