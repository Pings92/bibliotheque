{% extends 'base.html.twig' %}

{% block title %}Emprunt index{% endblock %}

{% block body %}
    <h1></h1>
{# c'est la page de rendu des emprunts effectué par un client index html twig #}
<div class='container'>
    {% include 'layouts/_flash_message.html.twig' %}
    {% if app.user %}
        <table class="table">
            <thead>
                <tr>
                    {# <th>Id</th> #}
                    <th>Nom du livre</th>
                    <th>Date d'emprunt</th>
                    <th>Date de retour</th>
                    <th>Statut</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {# {% for user in users %} #}
                {% for emprunt in emprunts %}
                    <tr>
                        {# <td>{{ emprunt.id }}</td> #}
                        {# <td>en attendant de trouver comment afficher le nom du client</td> #}
                        <td>{{ emprunt.book.title }}</td>
                        <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('d-m-Y H:i:s', "Europe/Paris") : '' }}</td>
                        <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('d-m-Y H:i:s', "Europe/Paris") : '' }}</td>
                        <td>
                            {% if emprunt.statut == "en cours" %}
                                <p class="badge bg-warning">En cours</p>
                            {% elseif emprunt.statut == "Restitué"%}
                                <p class="badge bg-danger">Terminé</p>
                            {% endif %}
                        </td>
                        <td>
                            {% if emprunt.statut == "en cours" %}
                                <a href="{{path('app_emprunt_return', {'id': emprunt.id}) }}" class="btn btn-primary">Restituer</a>
                                <a href="{{path('app_book_show', {'id': emprunt.book.id}) }}" class="btn btn-info">Détails</a>
                            {# <a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}">Restituer</a> #}
                            {% else %}
                                <p class="badge bg-success">Rendu</p>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucun emprunt en cours pour le moment.</td>
                    </tr>
                {% endfor %}
            {# {% endfor %} #}
            </tbody>
        </table>
    {% else %}
        <div>Veuillez créer vous <a href="{{path('app_login') }}" >connectez</a>. Nouveau par ici, <a href="{{path('app_register')}}" >inscrivez-vous!</a></div>
    {% endif %}
</div>
    {# <a href="{{ path('app_emprunt_new') }}">Create new</a> #}
{% endblock %}
